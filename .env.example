# Copy to .env and fill in. Do not commit .env (it is in .gitignore).
# Helius RPC (default when set): https://mainnet.helius-rpc.com/?api-key=KEY
HELIUS_API_KEY=your_helius_api_key_here

# Solana wallet private key (base58). If set, no prompt on node start.
# Keep .env readable only by you: chmod 600 .env
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Optional: default config path (endpoints JSON). Override with _config_path rosparam.
# ROSPY_X402_CONFIG=/path/to/endpoints.json

# --- RAID App (same values as in RAID server .env for your environment) ---
# Lab / current test fleet (replace for production).
ROBOT_FLEET_ENROLLMENT_SECRET=test1
RAID_TO_ROBOT_SECRET=test2
# Stable per-robot id for idempotent enroll (serial, MAC, UUID in flash):
# RAID_ENROLLMENT_KEY=my-robot-enrollment-key
# LAN address RAID uses to reach this robot HTTP (e.g. GET /health on x402 port):
# RAID_ENROLL_HOST=192.168.x.x
# Optional: same as rosparam ~raid_app_url if not using mDNS
# RAID_APP_URL=http://raid-app.local:3000
